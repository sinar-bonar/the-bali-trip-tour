---
// Desktop navigation
const navLinks = [
  { href: '#products', label: 'Products' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white shadow-md h-[60px] flex items-center px-[10px]">
  <div class="max-w-[1200px] mx-auto w-full flex items-center justify-between">
    <!-- Left: Logo + Nav -->
    <div class="flex items-center flex-1">
      <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-2 no-underline">
        <img
          src={`${import.meta.env.BASE_URL}images/logo/logo.png`}
          alt="Bali Grand Tour"
          class="h-[36px] w-auto md:h-[44px] cursor-pointer"
        />
        <span class="text-sm md:text-base font-bold text-primary">Bali Grand Tour</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-5">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm font-bold text-primary hover:text-primary-light transition-colors"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Right: Contact -->
    <div class="hidden md:flex items-center gap-3 text-primary">
      <a
        href="tel:+628179780980"
        class="flex items-center gap-1 text-sm font-medium hover:text-primary-light transition-colors"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" width="16" height="16">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02z"/>
        </svg>
        +62 817 9780 980
      </a>
    </div>

    <!-- Mobile hamburger -->
    <div class="md:hidden">
      <a href="#products" class="text-sm font-bold text-primary hover:text-primary-light transition-colors">
        Products
      </a>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-[60px] w-full"></div>
