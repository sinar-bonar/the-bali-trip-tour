<footer class="bg-primary text-white py-10 px-[15px] md:px-[30px] mt-auto">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Company Info -->
    <div>
      <h3 class="text-lg font-bold mb-4">Bali Grand Tour</h3>
      <p class="text-sm leading-relaxed opacity-90">
        Exploring Bali's beauty, culture, and adventure with meticulously crafted one-day tours.
