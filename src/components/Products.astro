---
import { tours } from '../data/tours';
---

<section id="products" class="w-full px-[15px] md:px-[30px] max-w-[1200px] mx-auto">
  <h2 class="text-primary text-center text-[22px] md:text-[26px] font-bold my-[20px] md:my-[30px]">
    Our Products
  </h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-[100px]">
    {tours.map((tour) => (
      <a
        href={`${import.meta.env.BASE_URL}tour/${tour.slug}/`}
        class="block w-full max-w-full rounded-xl shadow-md overflow-hidden bg-white hover:shadow-lg transition-shadow duration-300 border border-gray-100"
      >
        <!-- Image -->
        <div class="relative">
          <img
            src={tour.image}
            alt={tour.title}
            class="w-full h-[208px] object-cover"
            loading="lazy"
          />
        </div>

        <!-- Info -->
        <div class="p-5 flex flex-col gap-3">
          <!-- Location -->
          <div class="flex items-center text-subtext">
            <svg class="w-4 h-4 mr-1.5 text-subtext flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" width="16" height="16">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7m0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5"/>
            </svg>
            <span class="text-sm">{tour.location}</span>
          </div>

          <!-- Title -->
          <h3 class="text-base font-bold leading-snug text-text">
            {tour.title}
          </h3>

          <!-- WhatsApp Book button -->
          <span
            class="mt-1 inline-flex items-center justify-center gap-2 bg-primary-button hover:bg-primary-dark text-white text-sm font-medium py-2.5 px-4 rounded-lg transition-colors duration-200 w-full"
          >
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" width="16" height="16">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Book via WhatsApp
          </span>
        </div>
      </a>
    ))}
  </div>
</section>
