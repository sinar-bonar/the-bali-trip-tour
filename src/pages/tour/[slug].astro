---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { tours } from '../../data/tours';

export function getStaticPaths() {
  return tours.map((tour) => ({
    params: { slug: tour.slug },
    props: { tour },
  }));
}

const { tour } = Astro.props;
const waUrl = `https://wa.me/628179780980?text=Hi%20The%20Bali%20Trip%20Tour%2C%20I%27m%20interested%20in%20${encodeURIComponent(tour.title)}`;
---

<Layout>
  <Header />

  <main class="flex-1">
    <!-- Hero Image -->
    <section class="w-full">
      <img
        src={tour.image}
        alt={tour.title}
        class="w-full h-[300px] md:h-[450px] object-cover"
      />
    </section>

    <!-- Content -->
    <section class="max-w-[800px] mx-auto px-[15px] md:px-[30px] py-8">
      <!-- Location -->
      <div class="flex items-center text-subtext mb-3">
        <svg class="w-4 h-4 mr-1.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" width="16" height="16">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7m0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5"/>
        </svg>
        <span>{tour.location}</span>
      </div>

      <!-- Title -->
      <h1 class="text-2xl md:text-3xl font-bold text-text mb-6">
        {tour.title}
      </h1>

      <!-- Description -->
      <div class="text-text leading-relaxed mb-8">
        <p>{tour.description}</p>
      </div>

      <!-- Highlights -->
      <h2 class="text-lg font-bold text-primary mb-4">Tour Highlights</h2>
      <ul class="space-y-3 mb-10">
        {tour.highlights.map((item) => (
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-primary" fill="currentColor" viewBox="0 0 24 24" width="20" height="20">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>

      <!-- WhatsApp CTA -->
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white font-medium py-3 px-6 rounded-lg transition-colors duration-200 w-full md:w-auto md:min-w-[300px]"
      >
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" width="20" height="20">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Book This Tour via WhatsApp
      </a>

      <!-- Back link -->
      <div class="mt-8">
        <a href={`${import.meta.env.BASE_URL}#products`} class="text-primary hover:text-primary-light text-sm font-medium transition-colors">
          ← Back to all tours
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton />
</Layout>
